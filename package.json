{
  "name": "ezeval",
  "version": "0.1.0",
  "description": "Lightweight CLI for gating structured AI changes before release",
  "private": true,
  "packageManager": "pnpm@10.6.3",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "bin": {
    "ezeval": "./dist/bin/ezeval.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "ezeval": "node --import tsx ./bin/ezeval.ts",
    "ezeval:init": "node --import tsx ./bin/ezeval.ts init --template ticket-triage --out ./ezeval.config.json",
    "ezeval:sample": "node --import tsx ./bin/ezeval.ts run --dataset ./examples/ticket-triage/dataset.jsonl --config ./examples/ticket-triage/config.ezeval.json --out ./.artifacts/report.json",
    "ezeval:sample:openai": "node --import tsx ./bin/ezeval.ts run --dataset ./examples/ticket-triage/dataset.jsonl --config ./examples/ticket-triage/config.ezeval.json --provider openai --model gpt-4.1-mini --api-key \"$OPENAI_API_KEY\" --out ./.artifacts/report.json --fail-on-gate",
    "demo:pass": "bash ./scripts/demo-pass.sh",
    "demo:fail": "bash ./scripts/demo-fail.sh"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}

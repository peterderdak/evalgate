{
  "name": "evalgate",
  "version": "0.1.0",
  "description": "CLI release gate for structured AI changes",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.6.3",
  "type": "module",
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "bin": {
    "evalgate": "./dist/bin/evalgate.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "evalgate": "node --import tsx ./bin/evalgate.ts",
    "evalgate:init": "node --import tsx ./bin/evalgate.ts init --template ticket-triage --out ./evalgate.config.json",
    "evalgate:sample": "node --import tsx ./bin/evalgate.ts run --dataset ./examples/ticket-triage/dataset.jsonl --config ./examples/ticket-triage/config.evalgate.json --out ./.artifacts/report.json",
    "evalgate:sample:openai": "OPENAI_API_KEY=\"$OPENAI_API_KEY\" node --import tsx ./bin/evalgate.ts run --dataset ./examples/ticket-triage/dataset.jsonl --config ./examples/ticket-triage/config.evalgate.json --provider openai --model gpt-4.1-mini --out ./.artifacts/report.json --fail-on-gate",
    "demo:pass": "bash ./scripts/demo-pass.sh",
    "demo:fail": "bash ./scripts/demo-fail.sh"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.8"
  }
}
